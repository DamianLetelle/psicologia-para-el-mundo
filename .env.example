# Variables de entorno (ejemplo). Copiar a .env.local y completar en la Fase 5.
# NO subir .env.local con valores reales — los secretos van fuera del código.

# Supabase (base de datos, login, storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago (pagos)
MERCADOPAGO_ACCESS_TOKEN=

# Resend (mail)
RESEND_API_KEY=

# Proveedores (opcional; por defecto: supabase / mercadopago / resend)
DB_PROVIDER=supabase
PAYMENTS_PROVIDER=mercadopago
MAILER_PROVIDER=resend
STORAGE_PROVIDER=supabase
